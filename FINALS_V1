<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Wireframe Layout</title>
    <style>
        /* Base Resets */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: #333333; 
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 20px 0;
        }

        /* Simulated browser window wrapper matching the screenshot template boundaries */
        .wireframe-container {
            width: 100%;
            max-width: 960px;
            background-color: #ffffff;
            display: flex;
            flex-direction: column;
        }

        /* Header Navbar Styling */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #ffffff;
            padding: 20px 40px;
            border-bottom: 3px solid #7f7f7f;
        }

        .nav-item {
            font-size: 26px;
            font-weight: bold;
            color: #000000;
        }

        .nav-item.center {
            flex-grow: 1;
            text-align: center;
        }

        /* Interactive Search Bar Styling */
        .search-container {
            display: flex;
            align-items: center;
        }

        .wireframe-search {
            font-size: 22px;
            font-weight: bold;
            color: #000000;
            background-color: #ffffff;
            border: 3px solid #7f7f7f;
            padding: 8px 16px;
            border-radius: 8px;
            width: 200px;
            outline: none;
            text-align: right;
            transition: all 0.2s ease;
        }

        .wireframe-search:hover {
            border-color: #000000;
            background-color: #f5f5f5;
        }

        .wireframe-search:focus {
            border-color: #f7d74c; 
            background-color: #ffffff;
            text-align: left;
            box-shadow: 0 0 8px rgba(247, 215, 76, 0.5);
        }

        /* Top Block Section */
        .banner-block {
            background-color: #dbdbdb;
            padding: 90px 20px 100px 20px;
            text-align: center;
            position: relative;
        }

        .banner-title {
            font-size: 30px;
            font-weight: bold;
            color: #000000;
        }

        /* Grid layout matching the middle buttons strip row */
        .buttons-row-overlay {
            position: absolute;
            bottom: -50px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            gap: 30px;
            padding: 0 40px;
        }

        /* Dark Gray Outer Rounded Frame */
        .button-container {
            background-color: #7f7f7f;
            padding: 12px;
            border-radius: 24px;
            display: flex;
            justify-content: center;
            align-items: center;
            flex: 1;
            max-width: 180px;
            height: 100px;
            box-shadow: 0px 4px 8px rgba(0,0,0,0.15);
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Yellow Inner Core Pill */
        .yellow-pill {
            background-color: #f7d74c;
            color: #000000;
            font-size: 22px;
            font-weight: bold;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 16px;
            user-select: none;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Button Hover Effects */
        .button-container:hover {
            transform: translateY(-5px) scale(1.03);
            background-color: #616161;
            box-shadow: 0px 8px 16px rgba(0,0,0,0.3);
        }

        .button-container:hover .yellow-pill {
            background-color: #ffeb3b; 
        }

        /* Button Active Press Effects */
        .button-container:active {
            transform: translateY(-1px) scale(0.98);
            box-shadow: 0px 2px 4px rgba(0,0,0,0.2);
        }

        .button-container:active .yellow-pill {
            background-color: #f5b041; 
        }

        /* Bottom Block Section */
        .news-block {
            background-color: #c9c9c9;
            padding: 120px 20px 80px 20px;
            text-align: center;
        }

        .news-text {
            font-size: 26px;
            font-weight: bold;
            color: #000000;
            line-height: 1.4;
        }
    </style>
</head>
<body>

    <div class="wireframe-container">
        <header class="navbar">
            <div class="nav-item left">smth</div>
            <div class="nav-item center">home buttons</div>
            
            <div class="search-container">
                <input type="text" class="wireframe-search" placeholder="search bar">
            </div>
        </header>

        <section class="banner-block">
            <h1 class="banner-title">Background photos idk</h1>
            
            <div class="buttons-row-overlay">
                <div class="button-container">
                    <div class="yellow-pill">buttons</div>
                </div>
                <div class="button-container">
                    <div class="yellow-pill">buttons</div>
                </div>
                <div class="button-container">
                    <div class="yellow-pill">buttons</div>
                </div>
                <div class="button-container">
                    <div class="yellow-pill">buttons</div>
                </div>
            </div>
        </section>

        <section class="news-block">
            <p class="news-text">
                put some news here idk<br>
                about the government or smthin
            </p>
        </section>
    </div>

</body>
</html>
